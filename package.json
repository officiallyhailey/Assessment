{
  "name": "backend-lessons",
  "version": "1.0.0",
  "private": true,
  "description": "Teaching app for the Backend Assessment lessons",
  "scripts": {
    "check": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/check-lessons.mjs",
    "predev": "npm run check",
    "dev": "concurrently -n API,APP -c green,cyan \"npm run server\" \"npm run client\"",
    "server": "node server/server.js",
    "client": "vite",
    "build": "vite build",
    "reset": "node server/reset.js",
    "lesson2": "cd lesson/lesson-2-post/complete && node server.js",
    "lesson2:scaffold": "cd lesson/lesson-2-post/scaffold && node server.js",
    "lesson3": "cd lesson/lesson-3-react/complete && node server.js",
    "lesson3:scaffold": "cd lesson/lesson-3-react/scaffold && node server.js",
    "lesson:reset": "node lesson/reset.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "vite": "^5.4.8"
  }
}
